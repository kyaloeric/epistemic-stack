# Pick ONE provider — set its key and (optionally) its model. The pipeline auto-detects.
# Or use no key at all via the dry-run path: python -m src.dryrun prompt ...

# --- Anthropic (Claude) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- OpenAI ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# --- DeepSeek ---
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat

# --- Any OpenAI-compatible endpoint (Groq, Together, Mistral, Ollama, ...) ---
# OPENAI_COMPAT_API_KEY=...
# OPENAI_COMPAT_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_COMPAT_MODEL=llama-3.3-70b-versatile

# Force a specific provider when several keys are set:
# EPISTEMIC_PROVIDER=deepseek
